{
  "name": "@aether/ts-host",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "TypeScript orchestration host for the Aether hybrid runtime. Calls Go manifests and finalizers, dispatches platform workers, never writes .aether/data/ directly.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:update-snapshots": "AETHER_UPDATE_SNAPSHOTS=1 tsx --test test/*.test.ts"
  },
  "dependencies": {
    "boxen": "8.0.1",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "cli-progress": "3.12.0",
    "figlet": "1.11.0",
    "js-yaml": "4.1.0",
    "log-update": "8.0.0",
    "ora": "9.4.0",
    "strip-ansi": "7.2.0"
  },
  "devDependencies": {
    "@types/cli-progress": "3.11.6",
    "@types/figlet": "1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
